<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F3FF">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#EC4899"
        android:padding="20dp"
        android:paddingTop="28dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reminders"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Never miss a study session"
            android:textSize="13sp"
            android:textColor="#FCE7F3"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Add reminder card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/white"
        android:padding="16dp"
        android:layout_margin="16dp"
        android:elevation="2dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add New Reminder"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#EC4899"
            android:layout_marginBottom="10dp"/>
        <EditText
            android:id="@+id/edtReminderTitle"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Title  e.g. Study Maths"
            android:inputType="textCapSentences"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@drawable/input_bg"
            android:textColor="#1E1B4B"
            android:textSize="13sp"
            android:layout_marginBottom="10dp"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <EditText
                android:id="@+id/edtReminderTime"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="Time  e.g. 6:00 PM"
                android:inputType="text"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@drawable/input_bg"
                android:textColor="#1E1B4B"
                android:textSize="13sp"
                android:layout_marginEnd="10dp"/>
            <TextView
                android:id="@+id/btnAddReminder"
                android:layout_width="80dp"
                android:layout_height="48dp"
                android:text="+ Add"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="@drawable/btn_pink"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Reminders label -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Your Reminders"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1E1B4B"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Long press to delete"
            android:textSize="11sp"
            android:textColor="#9CA3AF"/>
    </LinearLayout>

    <ListView
        android:id="@+id/lvReminders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:clipToPadding="false"
        android:divider="@null"
        android:dividerHeight="0dp"/>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp">
        <LinearLayout android:id="@+id/navHome" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/home"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" android:textSize="10sp" android:textColor="#6B7280"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navTasks" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/task"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tasks" android:textSize="10sp" android:textColor="#6B7280"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navReminders" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/reminder"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reminders" android:textSize="10sp" android:textColor="#EC4899"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navProfile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/avatar"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profile" android:textSize="10sp" android:textColor="#6B7280"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>