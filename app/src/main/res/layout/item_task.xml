<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/task_item_bg"
    android:padding="14dp"
    android:gravity="center_vertical"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/tvTaskDot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/dot_purple"
        android:layout_marginEnd="12dp"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTaskTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1E1B4B"/>

        <TextView
            android:id="@+id/tvTaskStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap to complete  |  Long press to delete"
            android:textSize="11sp"
            android:textColor="#9CA3AF"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvTaskCheck"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:text="✓"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:background="@drawable/check_bg_inactive"
        android:visibility="visible"/>

</LinearLayout>