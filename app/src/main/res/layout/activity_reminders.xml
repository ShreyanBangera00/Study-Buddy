<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F3FF">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="4dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reminders"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1E1B4B"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Set reminders for your study sessions"
            android:textSize="13sp"
            android:textColor="#6B7280"/>
    </LinearLayout>

    <!-- Add reminder inputs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/white"
        android:padding="16dp"
        android:layout_margin="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add New Reminder"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1E1B4B"
            android:layout_marginBottom="10dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Title"
            android:textSize="13sp"
            android:textColor="#374151"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etReminderTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. Study Maths"
            android:inputType="textCapSentences"
            android:padding="12dp"
            android:layout_marginBottom="12dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Time"
            android:textSize="13sp"
            android:textColor="#374151"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etReminderTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. 6:00 PM"
            android:inputType="text"
            android:padding="12dp"
            android:layout_marginBottom="12dp"/>
        <Button
            android:id="@+id/btnAddReminder"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Add Reminder"
            android:textColor="#FFFFFF"
            android:background="@drawable/purple"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Reminders"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#1E1B4B"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="4dp"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Long press a reminder to delete it"
        android:textSize="11sp"
        android:textColor="#9CA3AF"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="8dp"/>
    <ListView
        android:id="@+id/lvReminders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:divider="@null"
        android:dividerHeight="8dp"/>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp">
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/home"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="10sp"
                android:textColor="#6B7280"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/navTasks"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/task"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tasks"
                android:textSize="10sp"
                android:textColor="#6B7280"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/navReminders"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/reminder"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reminders"
                android:textSize="10sp"
                android:textColor="#7C3AED"/>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/avatar"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="10sp"
                android:textColor="#6B7280"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>