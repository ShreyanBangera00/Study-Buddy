<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F3FF">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:background="#7C3AED"
        android:padding="20dp" android:paddingTop="28dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="My Tasks" android:textSize="24sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Stay on top of your studies" android:textSize="13sp" android:textColor="#DDD6FE" android:layout_marginTop="2dp"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:overScrollMode="never" android:fillViewport="true">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Search bar -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp" android:paddingBottom="8dp">
                <EditText android:id="@+id/edtSearch"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:hint="🔍  Search tasks..." android:inputType="text"
                    android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:background="@drawable/input_bg" android:textSize="13sp"
                    android:textColor="#1E1B4B"/>
            </LinearLayout>

            <!-- Filter chips row -->
            <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingBottom="8dp"
                android:scrollbars="none">
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView android:id="@+id/chipAll"
                        android:layout_width="wrap_content" android:layout_height="32dp"
                        android:text="All" android:textSize="12sp" android:textStyle="bold"
                        android:textColor="#FFFFFF" android:gravity="center"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:background="@drawable/chip_selected"
                        android:layout_marginEnd="8dp"
                        android:clickable="true" android:focusable="true"/>

                    <TextView android:id="@+id/chipPending"
                        android:layout_width="wrap_content" android:layout_height="32dp"
                        android:text="Pending" android:textSize="12sp"
                        android:textColor="#7C3AED" android:gravity="center"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:background="@drawable/chip_unselected"
                        android:layout_marginEnd="8dp"
                        android:clickable="true" android:focusable="true"/>

                    <TextView android:id="@+id/chipDone"
                        android:layout_width="wrap_content" android:layout_height="32dp"
                        android:text="Done" android:textSize="12sp"
                        android:textColor="#7C3AED" android:gravity="center"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:background="@drawable/chip_unselected"
                        android:layout_marginEnd="8dp"
                        android:clickable="true" android:focusable="true"/>

                    <TextView android:id="@+id/chipHigh"
                        android:layout_width="wrap_content" android:layout_height="32dp"
                        android:text="🔴 High" android:textSize="12sp"
                        android:textColor="#EF4444" android:gravity="center"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:background="@drawable/chip_unselected"
                        android:layout_marginEnd="8dp"
                        android:clickable="true" android:focusable="true"/>

                    <TextView android:id="@+id/chipMedium"
                        android:layout_width="wrap_content" android:layout_height="32dp"
                        android:text="🟡 Medium" android:textSize="12sp"
                        android:textColor="#F59E0B" android:gravity="center"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:background="@drawable/chip_unselected"
                        android:layout_marginEnd="8dp"
                        android:clickable="true" android:focusable="true"/>

                    <TextView android:id="@+id/chipLow"
                        android:layout_width="wrap_content" android:layout_height="32dp"
                        android:text="🟢 Low" android:textSize="12sp"
                        android:textColor="#10B981" android:gravity="center"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:background="@drawable/chip_unselected"
                        android:clickable="true" android:focusable="true"/>

                </LinearLayout>
            </HorizontalScrollView>

            <!-- Add task card -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="@drawable/white"
                android:padding="16dp" android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp" android:layout_marginBottom="12dp" android:elevation="2dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Add New Task" android:textSize="13sp" android:textStyle="bold"
                    android:textColor="#7C3AED" android:layout_marginBottom="10dp"/>

                <EditText android:id="@+id/edtTaskName"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:hint="e.g. Study Chapter 3" android:inputType="textCapSentences"
                    android:paddingStart="14dp" android:paddingEnd="14dp"
                    android:background="@drawable/input_bg" android:textColor="#1E1B4B"
                    android:textSize="13sp" android:layout_marginBottom="10dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Priority" android:textSize="12sp" android:textStyle="bold"
                    android:textColor="#374151" android:layout_marginBottom="6dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="10dp">
                    <TextView android:id="@+id/btnPriorityHigh" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                        android:text="🔴 High" android:textSize="12sp" android:textStyle="bold"
                        android:textColor="#EF4444" android:gravity="center"
                        android:background="@drawable/priority_btn_unselected"
                        android:layout_marginEnd="6dp" android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/btnPriorityMedium" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                        android:text="🟡 Medium" android:textSize="12sp" android:textStyle="bold"
                        android:textColor="#FFFFFF" android:gravity="center"
                        android:background="@drawable/priority_btn_selected_amber"
                        android:layout_marginEnd="6dp" android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/btnPriorityLow" android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
                        android:text="🟢 Low" android:textSize="12sp" android:textStyle="bold"
                        android:textColor="#10B981" android:gravity="center"
                        android:background="@drawable/priority_btn_unselected"
                        android:clickable="true" android:focusable="true"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/btnPickDate" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                        android:text="📅  Pick Due Date" android:textSize="13sp"
                        android:textColor="#7C3AED" android:gravity="center"
                        android:background="@drawable/input_bg" android:layout_marginEnd="10dp"
                        android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/btnAddTask" android:layout_width="80dp" android:layout_height="48dp"
                        android:text="+ Add" android:textSize="13sp" android:textStyle="bold"
                        android:textColor="#FFFFFF" android:gravity="center"
                        android:background="@drawable/purple"
                        android:clickable="true" android:focusable="true"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Tasks label -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp"
                android:paddingBottom="8dp" android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Your Tasks" android:textSize="15sp" android:textStyle="bold" android:textColor="#1E1B4B"/>
                <TextView android:id="@+id/tvResultCount" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="#9CA3AF"/>
            </LinearLayout>

            <ListView android:id="@+id/lvTasks"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingBottom="8dp"
                android:clipToPadding="false" android:divider="@null" android:dividerHeight="0dp"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Nav -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="60dp"
        android:orientation="horizontal" android:background="#FFFFFF" android:elevation="8dp">
        <LinearLayout android:id="@+id/navHome" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/home"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" android:textSize="10sp" android:textColor="#6B7280"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navTasks" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/task"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tasks" android:textSize="10sp" android:textColor="#7C3AED"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navReminders" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/reminder"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Reminders" android:textSize="10sp" android:textColor="#6B7280"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/navProfile" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/avatar"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profile" android:textSize="10sp" android:textColor="#6B7280"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>